<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodeRev.App.ViewModels"
        xmlns:m="using:CodeRev.Core.Models"
        xmlns:hist="using:CodeRev.Core.History"
        xmlns:conv="using:CodeRev.App.Converters"
        xmlns:ctrl="using:CodeRev.App.Controls"
        xmlns:loc="using:CodeRev.App.Localization"
        x:Class="CodeRev.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1040" Height="700"
        Icon="/Assets/coderev.png"
        Title="coderev Desktop">

  <Window.Resources>
    <conv:DiffBackgroundConverter x:Key="DiffBg"/>
    <conv:DiffLineNumberConverter x:Key="LineNo"/>
    <conv:SeverityBrushConverter x:Key="SevBg"/>
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto" Margin="12">

    <!-- Setup bar -->
    <Border Grid.Row="0" Padding="10" Margin="0,0,0,10"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="6">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr RepoLabel}" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,4">
            <Button DockPanel.Dock="Right" Content="📂" Click="OnBrowseRepo" Margin="6,0,0,0"
                    ToolTip.Tip="{loc:Tr BrowseTip}"/>
            <TextBox Watermark="{loc:Tr RepoWatermark}" Text="{Binding RepositoryPath}"/>
          </DockPanel>
          <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Tr BranchLabel}" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <AutoCompleteBox Grid.Row="0" Grid.Column="3" Width="200" Watermark="feature/x"
                           Text="{Binding Branch}" ItemsSource="{Binding Branches}"
                           FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                           IsTextCompletionEnabled="False" Margin="0,0,0,4"/>

          <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                      Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{loc:Tr BaseLabel}" VerticalAlignment="Center"/>
            <TextBox Width="160" Text="{Binding BaseRef}" Watermark="origin/main"/>
            <TextBlock Text="{loc:Tr AgentLabel}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AgentOptions}" SelectedItem="{Binding Agent}" Width="150"/>
            <TextBlock Text="{loc:Tr ReviewLangLabel}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding LangOptions}" SelectedItem="{Binding Lang}" Width="150"/>
            <CheckBox Content="{loc:Tr DryRun}" IsChecked="{Binding DryRun}"/>
          </StackPanel>
        </Grid>

        <DockPanel>
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Tr InfoBtn}" Click="OnOpenAbout"/>
            <Button Content="{loc:Tr SettingsBtn}" Click="OnOpenConfigEditor"/>
            <Button Content="⤓ .md" Click="OnExportMarkdown" ToolTip.Tip="{loc:Tr ExportMdTip}"/>
            <Button Content="⤓ .html" Click="OnExportHtml" ToolTip.Tip="{loc:Tr ExportHtmlTip}"/>
            <Button Content="{loc:Tr ThemeBtn}" Click="OnToggleTheme"/>
            <Button Content="{loc:Tr UiLangToggle}" Click="OnToggleLanguage"/>
            <Button Content="{loc:Tr UpdateBtn}" Click="OnCheckForUpdates" ToolTip.Tip="{loc:Tr UpdateTip}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="{loc:Tr RunBtn}" Command="{Binding RunCommand}"/>
            <Button Content="{loc:Tr StopBtn}" Command="{Binding StopCommand}"/>
          </StackPanel>
        </DockPanel>
      </StackPanel>
    </Border>

    <!-- Main content: steps + tabs -->
    <Grid Grid.Row="1" ColumnDefinitions="280,*">
      <Border Grid.Column="0" Padding="8" Margin="0,0,10,0"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
              CornerRadius="6">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="{loc:Tr StepsHeader}" FontWeight="Bold" Margin="2,0,0,8"/>
          <TextBlock DockPanel.Dock="Bottom" Text="{Binding MetaText}"
                     TextWrapping="Wrap" Foreground="Gray" Margin="2,8,0,0"/>
          <ItemsControl ItemsSource="{Binding Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StepViewModel">
                <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                  <TextBlock Grid.Column="0" Text="{Binding Glyph}" Width="20"/>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Label}"/>
                    <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                               IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <TabControl Grid.Column="1">
        <!-- Review: color-coded, sectioned cards (falls back to raw stream) -->
        <TabItem Header="{loc:Tr TabReview}">
          <ScrollViewer>
            <StackPanel Margin="6">
              <ItemsControl ItemsSource="{Binding ReviewSections}" IsVisible="{Binding HasSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:ReviewSection">
                    <Border Margin="0,0,0,8" CornerRadius="6" BorderThickness="1" BorderBrush="#22808080">
                      <StackPanel>
                        <Border Background="{Binding Severity, Converter={StaticResource SevBg}}"
                                Padding="8,4" CornerRadius="6,6,0,0">
                          <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <ctrl:MarkdownView Markdown="{Binding Body}" Margin="10"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <SelectableTextBlock Text="{Binding ReviewText}" IsVisible="{Binding !HasSections}"
                                   FontFamily="Cascadia Code,Consolas,monospace" TextWrapping="Wrap"/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- Diff: file sidebar + colored, line-numbered rows -->
        <TabItem Header="{loc:Tr TabDiff}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="210" MinWidth="120"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,4,0">
              <Button DockPanel.Dock="Top" Content="{loc:Tr ShowAllFiles}" Command="{Binding ShowAllFilesCommand}"
                      HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
              <ListBox ItemsSource="{Binding DiffFiles}" SelectedItem="{Binding SelectedDiffFile}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:DiffFile">
                    <StackPanel>
                      <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="Gray"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                          Background="Transparent" ShowsPreview="False"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ToolTip.Tip="{loc:Tr DiffResizeTip}"/>

            <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding VisibleDiffLines}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:DiffLine">
                    <Border Background="{Binding Kind, Converter={StaticResource DiffBg}}">
                      <Grid ColumnDefinitions="48,*">
                        <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource LineNo}}"
                                   Foreground="Gray" TextAlignment="Right" Margin="0,0,8,0"
                                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding Text}"
                                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </TabItem>

        <TabItem Header="{loc:Tr TabHistory}">
          <DockPanel Margin="6">
            <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,6">
              <TextBlock Foreground="Gray" FontSize="11" Text="{loc:Tr HistoryHint}"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{loc:Tr HistRepoFilter}" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding RepositoryOptions}"
                          SelectedItem="{Binding RepositoryFilter}" MinWidth="200"/>
              </StackPanel>
            </StackPanel>
            <ListBox ItemsSource="{Binding History}" SelectedItem="{Binding SelectedHistoryEntry}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="hist:ReviewHistoryEntry">
                  <StackPanel Margin="0,2">
                    <DockPanel>
                      <Border DockPanel.Dock="Right" Background="#33808080" CornerRadius="4"
                              Padding="6,1" VerticalAlignment="Center" Margin="6,0,0,0"
                              IsVisible="{Binding Repository, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding Repository}" FontSize="10"/>
                      </Border>
                      <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                    <TextBlock FontSize="11" Foreground="Gray">
                      <Run Text="base:"/><Run Text="{Binding Base}"/>
                      <Run Text="  ·  agent:"/><Run Text="{Binding Agent}"/>
                      <Run Text="  ·  📄 "/><Run Text="{Binding ChangedFiles}"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </TabItem>

        <TabItem Header="{loc:Tr TabLog}">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Log}" Margin="6"/>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2" Padding="8,6" Margin="0,10,0,0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="6">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding AppVersion}" Foreground="Gray" Margin="12,0,0,0"/>
        <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
