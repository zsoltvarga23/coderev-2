<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodeRev.App.ViewModels"
        xmlns:m="using:CodeRev.Core.Models"
        xmlns:hist="using:CodeRev.Core.History"
        xmlns:conv="using:CodeRev.App.Converters"
        xmlns:ctrl="using:CodeRev.App.Controls"
        xmlns:loc="using:CodeRev.App.Localization"
        x:Class="CodeRev.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1040" Height="700"
        Icon="/Assets/coderev.png"
        Title="coderev Desktop">

  <Window.Resources>
    <conv:DiffLineNumberConverter x:Key="LineNo"/>
    <conv:SeverityBrushConverter x:Key="SevBg"/>

    <!-- Segmented-control look for the main tabs: pill segments, the selected one
         filled with the accent. Replaces the default underline tab header. -->
    <ControlTheme x:Key="{x:Type TabItem}" TargetType="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="16,7"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Name="PART_Pill" Background="{DynamicResource TabPillBg}" CornerRadius="8" Margin="0,0,4,0">
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pointerover /template/ Border#PART_Pill">
        <Setter Property="Background" Value="#28808080"/>
      </Style>
      <Style Selector="^:selected /template/ Border#PART_Pill">
        <Setter Property="Background" Value="{DynamicResource TabSelectedBg}"/>
      </Style>
      <Style Selector="^:selected">
        <Setter Property="Foreground" Value="#FFFFFF"/>
      </Style>
      <!-- Keyboard focus ring (accessibility). -->
      <Style Selector="^:focus-visible /template/ Border#PART_Pill">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}"/>
        <Setter Property="BorderThickness" Value="2"/>
      </Style>
    </ControlTheme>
  </Window.Resources>

  <Window.Styles>
    <!-- Theme-aware diff row backgrounds (brushes in App.axaml). Context rows
         carry no class and stay transparent. -->
    <Style Selector="Border.diffAdded">
      <Setter Property="Background" Value="{DynamicResource DiffAddedBg}"/>
    </Style>
    <Style Selector="Border.diffRemoved">
      <Setter Property="Background" Value="{DynamicResource DiffRemovedBg}"/>
    </Style>
    <Style Selector="Border.diffHunk">
      <Setter Property="Background" Value="{DynamicResource DiffHunkBg}"/>
    </Style>
    <Style Selector="Border.diffMeta">
      <Setter Property="Background" Value="{DynamicResource DiffMetaBg}"/>
    </Style>

    <!-- Step status icon colours. The running spinner rotates so it reads as
         live (a static spinner glyph would look broken). -->
    <Style Selector="TextBlock.stepRunning">
      <Setter Property="Foreground" Value="{DynamicResource StepRunning}"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="rotate(0)"/>
      <Style.Animations>
        <Animation Duration="0:0:0.9" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="TextBlock.stepDone">
      <Setter Property="Foreground" Value="{DynamicResource StepDone}"/>
    </Style>
    <Style Selector="TextBlock.stepFailed">
      <Setter Property="Foreground" Value="{DynamicResource StepFailed}"/>
    </Style>
    <Style Selector="TextBlock.stepCancelled">
      <Setter Property="Foreground" Value="{DynamicResource StepCancelled}"/>
    </Style>

    <!-- Centered empty-state placeholder. -->
    <Style Selector="StackPanel.placeholder">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Spacing" Value="8"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">

    <!-- Header: brand on the left, app-level icon actions on the right -->
    <DockPanel Grid.Row="0" Margin="2,0,2,10">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Classes="icon" FontSize="20" Foreground="{DynamicResource AppAccent}"
                   Text="{x:Static ctrl:Icons.GitPullRequest}"/>
        <TextBlock Text="coderev" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Classes="iconbtn" Click="OnUpdate" IsVisible="{Binding UpdateAvailable}"
                ToolTip.Tip="{Binding UpdateTipText}">
          <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.ArrowUp}"/>
        </Button>
        <Button Classes="iconbtn" Click="OnToggleTheme" ToolTip.Tip="{loc:Tr ThemeBtn}">
          <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.SunMoon}"/>
        </Button>
        <Button Classes="iconbtn" Click="OnToggleLanguage" ToolTip.Tip="{loc:Tr UiLangToggle}">
          <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.Language}"/>
        </Button>
        <Button Classes="iconbtn" Click="OnOpenAbout" ToolTip.Tip="{loc:Tr InfoBtn}">
          <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.InfoCircle}"/>
        </Button>
        <Button Classes="iconbtn" Click="OnOpenConfigEditor" ToolTip.Tip="{loc:Tr SettingsBtn}">
          <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.Settings}"/>
        </Button>
      </StackPanel>
    </DockPanel>

    <!-- Setup bar -->
    <Border Grid.Row="1" Padding="10" Margin="0,0,0,10"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr RepoLabel}" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,4">
            <Button DockPanel.Dock="Right" Click="OnBrowseRepo" Margin="6,0,0,0"
                    ToolTip.Tip="{loc:Tr BrowseTip}">
              <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.Folder}"/>
            </Button>
            <AutoCompleteBox Watermark="{loc:Tr RepoWatermark}" Text="{Binding RepositoryPath}"
                             ItemsSource="{Binding RecentRepositories}"
                             ValueMemberBinding="{Binding Path}"
                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                             IsTextCompletionEnabled="False"
                             x:Name="RepoBox">
              <AutoCompleteBox.ItemTemplate>
                <DataTemplate x:DataType="hist:RecentRepository">
                  <DockPanel>
                    <Button DockPanel.Dock="Right" Classes="iconbtn" Padding="5"
                            VerticalAlignment="Center" Click="OnRemoveRecent"
                            ToolTip.Tip="{loc:Tr RecentRemoveTip}">
                      <TextBlock Classes="icon" FontSize="14" Text="{x:Static ctrl:Icons.X}"/>
                    </Button>
                    <StackPanel Margin="0,1">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Path}" FontSize="10" Foreground="Gray"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </DockPanel>
                </DataTemplate>
              </AutoCompleteBox.ItemTemplate>
            </AutoCompleteBox>
          </DockPanel>
          <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Tr BranchLabel}" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <AutoCompleteBox Grid.Row="0" Grid.Column="3" Width="200" Watermark="feature/x"
                           Text="{Binding Branch}" ItemsSource="{Binding Branches}"
                           FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                           IsTextCompletionEnabled="False" Margin="0,0,0,4"
                           x:Name="BranchBox"/>

          <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                      Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{loc:Tr BaseLabel}" VerticalAlignment="Center"/>
            <AutoCompleteBox Width="170" Text="{Binding BaseRef}" Watermark="origin/main"
                             ItemsSource="{Binding BaseRefOptions}"
                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                             IsTextCompletionEnabled="False"
                             x:Name="BaseBox"/>
            <TextBlock Text="{loc:Tr AgentLabel}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AgentOptions}" SelectedItem="{Binding Agent}" Width="150"/>
            <TextBlock Text="{loc:Tr ReviewLangLabel}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding LangOptions}" SelectedItem="{Binding Lang}" Width="150"/>
          </StackPanel>
        </Grid>

        <DockPanel>
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
            <Button Click="OnExportMarkdown" ToolTip.Tip="{loc:Tr ExportMdTip}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.FileDownload}"/>
                <TextBlock Text=".md"/>
              </StackPanel>
            </Button>
            <Button Click="OnExportHtml" ToolTip.Tip="{loc:Tr ExportHtmlTip}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.FileDownload}"/>
                <TextBlock Text=".html"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <ToggleSwitch IsChecked="{Binding DryRun}" VerticalAlignment="Center"
                          OnContent="{loc:Tr DryRun}" OffContent="{loc:Tr DryRun}"/>
            <Button Classes="accent" Command="{Binding RunCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.PlayerPlay}"/>
                <TextBlock Text="{loc:Tr RunBtn}"/>
              </StackPanel>
            </Button>
            <Button Classes="danger" Command="{Binding StopCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.PlayerStop}"/>
                <TextBlock Text="{loc:Tr StopBtn}"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </DockPanel>
      </StackPanel>
    </Border>

    <!-- Main content: steps + tabs -->
    <Grid Grid.Row="2" ColumnDefinitions="280,*">
      <Border Grid.Column="0" Padding="8" Margin="0,0,10,0"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
              CornerRadius="6">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="{loc:Tr StepsHeader}" FontWeight="Bold" Margin="2,0,0,8"/>
          <TextBlock DockPanel.Dock="Bottom" Text="{Binding MetaText}"
                     TextWrapping="Wrap" Foreground="Gray" Margin="2,8,0,0"/>
          <ItemsControl ItemsSource="{Binding Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StepViewModel">
                <Grid ColumnDefinitions="Auto,*" Margin="0,4">
                  <Border Grid.Column="0" Width="22" Height="20" Margin="0,1,0,0">
                    <TextBlock Classes="icon" Text="{Binding Icon}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Classes.stepRunning="{Binding IsRunning}"
                               Classes.stepDone="{Binding IsDone}"
                               Classes.stepFailed="{Binding IsFailed}"
                               Classes.stepCancelled="{Binding IsCancelled}"/>
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Label}"/>
                    <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                               IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <!-- Tab order (Review, Diff, History, Log) must match the Tab* index
           constants in MainWindowViewModel that drive history-entry navigation. -->
      <TabControl Grid.Column="1" SelectedIndex="{Binding SelectedTab}">
        <!-- Review: color-coded, sectioned cards (falls back to raw stream) -->
        <TabItem Header="{loc:Tr TabReview}">
          <Grid>
            <ScrollViewer>
              <StackPanel Margin="6">
                <ItemsControl ItemsSource="{Binding ReviewSections}" IsVisible="{Binding HasSections}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="m:ReviewSection">
                      <Border Margin="0,0,0,8" CornerRadius="6" BorderThickness="1" BorderBrush="#22808080">
                        <StackPanel>
                          <Border Background="{Binding Severity, Converter={StaticResource SevBg}}"
                                  Padding="8,4" CornerRadius="6,6,0,0">
                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"/>
                          </Border>
                          <ctrl:MarkdownView Markdown="{Binding Body}" Margin="10"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <SelectableTextBlock Text="{Binding ReviewText}" IsVisible="{Binding !HasSections}"
                                     FontFamily="Cascadia Code,Consolas,monospace" TextWrapping="Wrap"/>
              </StackPanel>
            </ScrollViewer>
            <StackPanel Classes="placeholder" IsVisible="{Binding ShowReviewPlaceholder}">
              <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.GitPullRequest}" FontSize="44"
                         Foreground="Gray" HorizontalAlignment="Center"/>
              <TextBlock Text="{loc:Tr ReviewEmptyTitle}" FontSize="15" FontWeight="Medium"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{loc:Tr ReviewEmptyHint}" Foreground="Gray" TextAlignment="Center"
                         TextWrapping="Wrap" MaxWidth="320"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <!-- Diff: file sidebar + colored, line-numbered rows -->
        <TabItem Header="{loc:Tr TabDiff}">
          <Grid>
            <Grid IsVisible="{Binding HasDiff}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="210" MinWidth="120"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,4,0">
              <Button DockPanel.Dock="Top" Command="{Binding ShowAllFilesCommand}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.List}"/>
                  <TextBlock Text="{loc:Tr ShowAllFiles}"/>
                </StackPanel>
              </Button>
              <ListBox ItemsSource="{Binding DiffFiles}" SelectedItem="{Binding SelectedDiffFile}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:DiffFile">
                    <StackPanel>
                      <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="Gray"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                          Background="Transparent" ShowsPreview="False"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ToolTip.Tip="{loc:Tr DiffResizeTip}"/>

            <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding VisibleDiffLines}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:DiffLine">
                    <Border Classes.diffAdded="{Binding IsAdded}"
                            Classes.diffRemoved="{Binding IsRemoved}"
                            Classes.diffHunk="{Binding IsHunk}"
                            Classes.diffMeta="{Binding IsMeta}">
                      <Grid ColumnDefinitions="48,*">
                        <TextBlock Grid.Column="0" Text="{Binding Converter={StaticResource LineNo}}"
                                   Foreground="Gray" TextAlignment="Right" Margin="0,0,8,0"
                                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding Text}"
                                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            </Grid>
            <StackPanel Classes="placeholder" IsVisible="{Binding !HasDiff}">
              <TextBlock Classes="icon" Text="{x:Static ctrl:Icons.FileDiff}" FontSize="44"
                         Foreground="Gray" HorizontalAlignment="Center"/>
              <TextBlock Text="{loc:Tr DiffEmptyTitle}" FontSize="15" FontWeight="Medium"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{loc:Tr DiffEmptyHint}" Foreground="Gray" TextAlignment="Center"
                         TextWrapping="Wrap" MaxWidth="320"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="{loc:Tr TabHistory}">
          <DockPanel Margin="6">
            <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,6">
              <TextBlock Foreground="Gray" FontSize="11" Text="{loc:Tr HistoryHint}"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{loc:Tr HistRepoFilter}" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding RepositoryOptions}"
                          SelectedItem="{Binding RepositoryFilter}" MinWidth="200"/>
              </StackPanel>
            </StackPanel>
            <ListBox ItemsSource="{Binding History}" SelectedItem="{Binding SelectedHistoryEntry}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="hist:ReviewHistoryEntry">
                  <StackPanel Margin="0,2">
                    <DockPanel>
                      <Border DockPanel.Dock="Right" Background="#33808080" CornerRadius="4"
                              Padding="6,1" VerticalAlignment="Center" Margin="6,0,0,0"
                              IsVisible="{Binding Repository, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding Repository}" FontSize="10"/>
                      </Border>
                      <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                    <TextBlock FontSize="11" Foreground="Gray">
                      <Run Text="base:"/><Run Text="{Binding Base}"/>
                      <Run Text="  ·  agent:"/><Run Text="{Binding Agent}"/>
                      <Run Text="  ·  📄 "/><Run Text="{Binding ChangedFiles}"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </TabItem>

        <TabItem Header="{loc:Tr TabLog}">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Log}" Margin="6"/>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3" Padding="8,6" Margin="0,10,0,0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding AppVersion}" Foreground="Gray" Margin="12,0,0,0"/>
        <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
