<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:CodeRev.App.Localization"
        x:Class="CodeRev.App.Views.AboutWindow"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/coderev.png"
        Title="coderev Desktop — Info">

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="2">
      <TextBlock Text="coderev Desktop" FontWeight="Bold" FontSize="20"/>
      <TextBlock x:Name="SubtitleText" Foreground="Gray"/>
    </StackPanel>

    <Button DockPanel.Dock="Bottom" Content="{loc:Tr Close}" HorizontalAlignment="Right"
            Margin="0,12,0,0" Click="OnClose"/>

    <ScrollViewer Margin="0,12,0,0">
      <StackPanel Spacing="14" MaxWidth="500" HorizontalAlignment="Left">

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr AboutWhatHdr}" FontWeight="Bold" FontSize="15"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutWhatBody}"/>
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr AboutHowHdr}" FontWeight="Bold" FontSize="15"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutHow1}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutHow2}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutHow3}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutHow4}"/>
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr AboutAiHdr}" FontWeight="Bold" FontSize="15"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutAiBody}"/>
          <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" Text="{loc:Tr AboutAiCodex}"/>
          <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" Text="{loc:Tr AboutAiCopilot}"/>
          <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" Text="{loc:Tr AboutAiClaude}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutAiCustom}"/>
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Tr AboutNeedHdr}" FontWeight="Bold" FontSize="15"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutNeedGit}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutNeedAgent}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutNeedEngine}"/>
          <TextBlock TextWrapping="Wrap" Text="{loc:Tr AboutNeedTip}"/>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
