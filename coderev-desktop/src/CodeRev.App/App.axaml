<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CodeRev.App.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <!-- Diff row backgrounds, tuned per theme. The previous single set of
           ~19%-alpha colors was nearly invisible on the dark background; the
           dark variant uses brighter greens/reds at higher alpha. Referenced as
           DynamicResource so they re-resolve live when the theme is toggled. -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="DiffAddedBg" Color="#332EA043"/>
          <SolidColorBrush x:Key="DiffRemovedBg" Color="#33CB2431"/>
          <SolidColorBrush x:Key="DiffHunkBg" Color="#220366D6"/>
          <SolidColorBrush x:Key="DiffMetaBg" Color="#22808080"/>
          <!-- Markdown code (review view): a subtly darker panel on light. -->
          <SolidColorBrush x:Key="CodeBlockBg" Color="#0F000000"/>
          <SolidColorBrush x:Key="CodeBlockBorder" Color="#25000000"/>
          <SolidColorBrush x:Key="CodeInlineBg" Color="#14000000"/>
          <!-- Brand/primary accent (green). -->
          <SolidColorBrush x:Key="AppAccent" Color="#2DA44E"/>
          <SolidColorBrush x:Key="AppAccentHover" Color="#278C42"/>
          <!-- Selected tab pill: a calmer green so it isn't garish. -->
          <SolidColorBrush x:Key="TabSelectedBg" Color="#3C9A6A"/>
          <!-- Subtle background for unselected tab pills (visible on light). -->
          <SolidColorBrush x:Key="TabPillBg" Color="#14000000"/>
          <!-- Stop / destructive action. -->
          <SolidColorBrush x:Key="AppDanger" Color="#CB2431"/>
          <SolidColorBrush x:Key="AppDangerHover" Color="#A81F2B"/>
          <!-- Step status colours. -->
          <SolidColorBrush x:Key="StepRunning" Color="#378ADD"/>
          <SolidColorBrush x:Key="StepDone" Color="#2EA043"/>
          <SolidColorBrush x:Key="StepFailed" Color="#CB2431"/>
          <SolidColorBrush x:Key="StepCancelled" Color="#888780"/>
          <!-- ToggleSwitch "on" state recoloured to the app green (dry-run). -->
          <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#2DA44E"/>
          <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#278C42"/>
          <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#278C42"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#2DA44E"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#278C42"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#278C42"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="DiffAddedBg" Color="#553FB950"/>
          <SolidColorBrush x:Key="DiffRemovedBg" Color="#55F85149"/>
          <SolidColorBrush x:Key="DiffHunkBg" Color="#403B82F6"/>
          <SolidColorBrush x:Key="DiffMetaBg" Color="#33A0A0A0"/>
          <!-- Markdown code (review view): a subtly lighter panel on dark. -->
          <SolidColorBrush x:Key="CodeBlockBg" Color="#1FFFFFFF"/>
          <SolidColorBrush x:Key="CodeBlockBorder" Color="#33FFFFFF"/>
          <SolidColorBrush x:Key="CodeInlineBg" Color="#1FFFFFFF"/>
          <!-- Brand/primary accent (green), lifted for the dark canvas. -->
          <SolidColorBrush x:Key="AppAccent" Color="#3FB950"/>
          <SolidColorBrush x:Key="AppAccentHover" Color="#54C268"/>
          <SolidColorBrush x:Key="TabSelectedBg" Color="#46A876"/>
          <SolidColorBrush x:Key="TabPillBg" Color="#18FFFFFF"/>
          <SolidColorBrush x:Key="AppDanger" Color="#F85149"/>
          <SolidColorBrush x:Key="AppDangerHover" Color="#FA6B63"/>
          <!-- Step status colours (brighter for the dark canvas). -->
          <SolidColorBrush x:Key="StepRunning" Color="#5BA3E8"/>
          <SolidColorBrush x:Key="StepDone" Color="#3FB950"/>
          <SolidColorBrush x:Key="StepFailed" Color="#F85149"/>
          <SolidColorBrush x:Key="StepCancelled" Color="#9C9A92"/>
          <!-- ToggleSwitch "on" state, brighter green for the dark canvas. -->
          <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#3FB950"/>
          <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#54C268"/>
          <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#54C268"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#3FB950"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#54C268"/>
          <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#54C268"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- Bundled icon font: a subset of Tabler Icons (MIT). Glyph constants in
           Controls/Icons.cs. -->
      <FontFamily x:Key="IconFont">avares://CodeRev.App/Assets/coderev-icons.ttf#tabler-icons</FontFamily>

      <!-- Rounder corners on inputs/buttons across the app (matches the design). -->
      <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!-- Hand cursor on enabled interactive controls (buttons, switch, combo,
         tabs); disabled controls keep the default arrow. -->
    <Style Selector="Button:not(:disabled)">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ToggleSwitch:not(:disabled)">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ComboBox:not(:disabled)">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="TabItem:not(:disabled)">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Icon glyphs rendered from the bundled font. -->
    <Style Selector="TextBlock.icon">
      <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Primary (accent) button: filled green in every state. Target the
         ContentPresenter directly so it overrides Fluent's per-state fills. -->
    <Style Selector="Button.accent:not(:disabled)">
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.accent:not(:disabled) /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccent}"/>
      <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
    </Style>
    <Style Selector="Button.accent:not(:disabled):pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentHover}"/>
    </Style>
    <Style Selector="Button.accent:not(:disabled):pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentHover}"/>
    </Style>

    <!-- Destructive (Stop) button: red when enabled, dims when disabled. -->
    <Style Selector="Button.danger:not(:disabled)">
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.danger:not(:disabled) /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppDanger}"/>
      <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
    </Style>
    <Style Selector="Button.danger:not(:disabled):pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppDangerHover}"/>
    </Style>
    <Style Selector="Button.danger:not(:disabled):pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppDangerHover}"/>
    </Style>

    <!-- Icon-only toolbar button: square, flat, subtle hover. -->
    <Style Selector="Button.iconbtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="MinWidth" Value="0"/>
    </Style>
    <Style Selector="Button.iconbtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22808080"/>
    </Style>
  </Application.Styles>
</Application>
